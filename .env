# ─────────────────────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# CORS — comma-separated list of allowed front-end origins
# In production set this to your Netlify/Render URL only (no wildcard!)
# Example: CLIENT_ORIGIN=https://your-app.netlify.app,https://your-app.com
# ─────────────────────────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5500,http://localhost:3000,http://127.0.0.1:3000

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────
# Put your real MongoDB Atlas connection string below:
MONGODB_URI=

# ─────────────────────────────────────────────────────────────────────────────
# PAYMENT GATEWAY — Razorpay
# NEVER commit real keys to git. Use test keys locally only.
# ─────────────────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_ROWTPWuKMInZ63
RAZORPAY_KEY_SECRET=kcU5qwvXKqAK0uuwN6b2RcdW

# ─────────────────────────────────────────────────────────────────────────────
# JWT — User sessions
# Generate strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=149a01a20669a30267cb41ee625cf06c867483b6fbe556705c9bb633ee9c47ee402001c044f68e51af62ce8bf8cbbabd76392887c0315dded74944484c2779d7
JWT_EXPIRES_IN=2h

# ─────────────────────────────────────────────────────────────────────────────
# JWT — Admin sessions (separate secret, shorter expiry)
