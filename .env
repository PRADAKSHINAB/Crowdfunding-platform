ADMIN_JWT_SECRET=a07c08a5b0bd73f909a7b40f0dc6e3818c5961228a1aeebf1127e93b518d2bcf96421c62115de9712c1fbe062933bfa3e0b9affad70cd5a7f948c768d0459f52
ADMIN_JWT_EXPIRES_IN=4h

# ─────────────────────────────────────────────────────────────────────────────
# FIELD ENCRYPTION — Aadhaar & PAN are encrypted with AES-256-GCM
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes)
# ─────────────────────────────────────────────────────────────────────────────
FIELD_ENCRYPTION_KEY=f4c764bad6dc8a040b2333278f690151269bdd6d5335f435bc0063134bd27fac

# ─────────────────────────────────────────────────────────────────────────────
