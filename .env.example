# ─────────────────────────────────────────────────────────────────────────────
# .env.example — SAFE TO COMMIT. Contains NO real secrets.
# Copy this file to .env and fill in your actual values.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. Use specific URLs in production.
# Example: CLIENT_ORIGIN=https://your-app.netlify.app
CLIENT_ORIGIN=http://localhost:5500

# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── Razorpay Payment Gateway ────────────────────────────────────────────────
# Use TEST keys locally. Set LIVE keys only in your production deployment env vars.
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ─── JWT — User Sessions ──────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<generate-128-char-hex-string>
JWT_EXPIRES_IN=2h

# ─── JWT — Admin Sessions (use a DIFFERENT secret from user JWT) ──────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_JWT_SECRET=<generate-another-128-char-hex-string>
ADMIN_JWT_EXPIRES_IN=4h

# ─── Field Encryption — Aadhaar & PAN (AES-256-GCM) ─────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes). NEVER change this after data is stored.
FIELD_ENCRYPTION_KEY=<generate-64-char-hex-string>

# ─── Admin Defaults (used on first boot only) ─────────────────────────────────
# Change immediately after first login!
ADMIN_DEFAULT_PASSWORD=<strong-password-min-8-chars-upper-lower-number>
ADMIN_INVITE_CODE=<your-secret-invite-code>
